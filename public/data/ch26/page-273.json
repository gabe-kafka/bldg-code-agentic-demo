    {
      "id": "ASCE7-22-26.5-prov1",
      "type": "provision",
      "section": "26.5",
      "text": "5. Wind speeds for Hawaii, US Virgin Islands, and Puerto Rico shall be determined from the ASCE Wind Design Geodatabase.",
      "cross_references": [],
      "bbox": {
        "x_start": 0.06,
        "x_end": 0.94,
        "y_start": 0.78,
        "y_end": 0.81
      },
